<p style="color: green"><%= notice %></p>

<%= render @case %>

<div>
  <%= link_to "Edit this case", edit_case_path(@case) %> |
  <%= link_to "Back to cases", cases_path %>

  <%= button_to "Destroy this case", @case, method: :delete %>

  <h3>Documents</h3>

  <% @case.documents.each do |doc| %>
    <p>
      <%= link_to doc.filename, url_for(doc) %>
    </p>
  <% end %>
</div>


